# =============================================================================
# Faezeh Salon - Environment Variables
# =============================================================================

# Django
DEBUG=True
SECRET_KEY=change-me-to-a-secure-random-string-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost

# Database (PostgreSQL)
POSTGRES_DB=faezeh_salon
POSTGRES_USER=faezeh_user
POSTGRES_PASSWORD=faezeh_secure_password_123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Zarinpal Payment
ZARINPAL_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ZARINPAL_SANDBOX=True

# Kavenegar SMS
KAVENEGAR_API_KEY=your-kavenegar-api-key-here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook/

# Cloudinary (optional - leave empty to use local storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL (for CORS and links)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Admin
ADMIN_PHONE=09399545113
