version: "3.9"

services:
  # ===========================================================================
  # PostgreSQL 16 - Main Database
  # ===========================================================================
  postgres:
    image: postgres:16-alpine
    container_name: faezeh_postgres
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    networks:
      - shared_network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER} -d $${POSTGRES_DB}"]
      interval: 5s
      timeout: 5s
      retries: 5

  # ===========================================================================
  # Redis 7 - Cache + Celery Broker
  # ===========================================================================
  redis:
    image: redis:7-alpine
    container_name: faezeh_redis
    restart: unless-stopped
    ports:
      - "6379:6379"
    networks:
      - shared_network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 5s
      retries: 5

  # ===========================================================================
  # Django Backend + Daphne (WebSocket)
  # ===========================================================================
  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: faezeh_backend
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - "8000:8000"
    volumes:
      - ./backend:/app
      - static_volume:/app/staticfiles
      - media_volume:/app/media
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - shared_network
    command: >
      sh -c "python manage.py migrate &&

             python manage.py collectstatic --noinput &&
             python manage.py create_default_admin &&
             daphne -b 0.0.0.0 -p 8000 config.asgi:application"

  # ===========================================================================
  # Celery Worker
  # ===========================================================================
  celery-worker:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: faezeh_celery_worker
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - ./backend:/app
      - media_volume:/app/media
    depends_on:
      - backend
      - redis
      - postgres
    networks:
      - shared_network
    command: celery -A config worker -l info

  # ===========================================================================
  # Celery Beat (Scheduler)
  # ===========================================================================
  celery-beat:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: faezeh_celery_beat
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - ./backend:/app
      - media_volume:/app/media
      - celery_beat_data:/app/celerybeat
    depends_on:
      - backend
      - redis
      - postgres
    networks:
      - shared_network
    command: celery -A config beat -l info --scheduler django_celery_beat.schedulers:DatabaseScheduler

  # ===========================================================================
  # Next.js Frontend
  # ===========================================================================
 # frontend:
 #   build:
 #     context: ./frontend
 #     dockerfile: Dockerfile
 #   container_name: faezeh_frontend
 #   restart: unless-stopped
 #   env_file:
 #     - .env
 #   ports:
 #     - "3000:3000"
 #   environment:
 #     - NEXT_PUBLIC_API_URL=http://localhost:8000
 #     - NEXT_PUBLIC_WS_URL=ws://localhost:8000
 #   depends_on:
 #     - backend
 #   networks:
 #     - shared_network

  # ===========================================================================
  # Nginx Reverse Proxy
  # ===========================================================================
  nginx:
    image: nginx:alpine
    container_name: faezeh_nginx
    restart: unless-stopped
    ports:
      - "80:80"
    volumes:
      - ./docker/nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - static_volume:/app/static:ro
      - media_volume:/app/media:ro
    depends_on:
      - backend
      - frontend
    networks:
      - shared_network

  # ===========================================================================
  # Telegram Bot (Optional - runs separately)
  # ===========================================================================
  telegram-bot:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: faezeh_telegram_bot
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - ./backend:/app
    depends_on:
      - backend
      - postgres
    networks:
      - shared_network
    command: python -m apps.telegram_bot.bot
    profiles:
      - bot

# =============================================================================
# Volumes
# =============================================================================
volumes:
  postgres_data:
  static_volume:
  media_volume:
  celery_beat_data:

# =============================================================================
# Networks
# =============================================================================
networks:
  shared_network:
    driver: bridge
